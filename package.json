{
  "name": "lumiflare-claude-context-generator",
  "version": "0.2.0",
  "description": "Auto-generate Claude Code context files (REPOSITORY_OVERVIEW.md, feature_list.md, CLAUDE.md, agents) for any repository",
  "type": "module",
  "bin": {
    "ccg": "./bin/cli.js"
  },
  "main": "./src/index.js",
  "files": [
    "bin/",
    "src/",
    "templates/"
  ],
  "scripts": {
    "test": "node --test src/**/*.test.js",
    "lint": "npx eslint src/"
  },
  "keywords": [
    "claude",
    "claude-code",
    "context",
    "ai",
    "code-generation",
    "developer-tools",
    "repository-analysis"
  ],
  "author": "lumiflare",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lumiflare/claude-context-generator"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "chalk": "^5.4.1",
    "ora": "^8.2.0",
    "fast-glob": "^3.3.3"
  }
}
